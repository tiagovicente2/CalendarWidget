<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="TextAppearance.CalendarWidget.BodyLarge" parent="TextAppearance.Material3.BodyLarge"/>
    <style name="TextAppearance.CalendarWidget.BodyMedium" parent="TextAppearance.Material3.BodyMedium"/>
    <style name="TextAppearance.CalendarWidget.HeadlineSmall" parent="TextAppearance.Material3.HeadlineSmall"/>
    <style name="TextAppearance.CalendarWidget.TitleLarge" parent="TextAppearance.Material3.TitleLarge"/>
    <style name="Theme.CalendarWidget" parent="Theme.Material3.DayNight.NoActionBar">
        
        <item name="colorPrimary">@color/purple_200</item>
        <item name="colorPrimaryContainer">@color/purple_700</item>
        <item name="colorOnPrimary">@color/purple_900</item>
        <item name="colorOnPrimaryContainer">@color/purple_100</item>
        
        
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryContainer">@color/teal_700</item>
        <item name="colorOnSecondary">@color/teal_900</item>
        <item name="colorOnSecondaryContainer">@color/teal_100</item>
        
        
        <item name="colorTertiary">@color/blue_200</item>
        <item name="colorTertiaryContainer">@color/blue_700</item>
        
        
        <item name="colorSurface">#1C1B1F</item>
        <item name="colorSurfaceVariant">@color/surface_variant_dark</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="colorOnSurfaceVariant">@color/gray_400</item>
        
        
        <item name="colorError">@color/error_dark</item>
        <item name="colorOnError">@color/black</item>
        
        
        <item name="android:statusBarColor">?attr/colorSurface</item>
        <item name="android:windowLightStatusBar">false</item>
        
        
        <item name="android:navigationBarColor">?attr/colorSurface</item>
        <item name="android:windowLightNavigationBar">false</item>
        
        
        <item name="textAppearanceHeadlineSmall">@style/TextAppearance.CalendarWidget.HeadlineSmall</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.CalendarWidget.TitleLarge</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.CalendarWidget.BodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.CalendarWidget.BodyMedium</item>
    </style>
</resources>